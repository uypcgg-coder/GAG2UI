settings().Rendering.QualityLevel = 1
local p = game:GetService("Players").LocalPlayer
local gardens = game:GetService("Workspace"):FindFirstChild("Gardens")

-- ====================================================================
-- LOGIC UTAMA LAHAN (MURNI HANCURIN LAHAN ORANG LAIN BIAR ANTI-LAG)
-- ====================================================================
local function filterLahan(plot)
    task.spawn(function()
        local ownerId = plot:GetAttribute("OwnerUserId")
        -- Tunggu sampai data OwnerUserId nongol dari server
        while not ownerId and plot.Parent do
            plot:GetAttributeChangedSignal("OwnerUserId"):Wait()
            ownerId = plot:GetAttribute("OwnerUserId")
        end
        
        -- Kalo lahan punya orang lain, langsung babat habis!
        if ownerId and tonumber(ownerId) ~= p.UserId then
            plot:Destroy()
        end
    end)
end

-- Jalankan fungsi untuk lahan yang udah ada dan lahan baru yang bakal muncul
if gardens then
    for _, plot in ipairs(gardens:GetChildren()) do filterLahan(plot) end
    gardens.ChildAdded:Connect(filterLahan)
end
